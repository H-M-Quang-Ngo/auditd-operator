#!/bin/sh
# Managed by auditd-operator charm. Do not edit manually.
# tlog-rec-session (setuid _tlog) opens the log sink with privilege;
# the recorded shell runs unprivileged as the connecting user.
user_shell=$(getent passwd "$(id -un)" | cut -d: -f7)
[ -n "$user_shell" ] || user_shell=/bin/sh

# sshd suppresses MOTD/login messages for ForceCommand sessions.
# PAM still regenerates /run/motd.dynamic during session setup, so re-emit it
# here for interactive logins.
if [ -z "$SSH_ORIGINAL_COMMAND" ] && [ ! -e "$HOME/.hushlogin" ]; then
  [ -s /run/motd.dynamic ] && cat /run/motd.dynamic 2>/dev/null
  [ -s /etc/motd ] && cat /etc/motd 2>/dev/null
fi

# Fail open: never dead-end a login if the recorder is unavailable (a missing or
# non-executable recorder must not lock everyone out). Drop into the real shell.
[ -x /usr/bin/tlog-rec-session ] || exec "$user_shell"

{% if session_recording_exclude_groups %}
# Exempt configured groups: drop their members into the real shell UNRECORDED.
# Comma-wrap both sides so the match is exact-token (g1 must not match g10 or xg1).
case ",$(id -nG "$(id -un)" | tr ' ' ','), " in
{% for g in session_recording_exclude_groups.split(',') %}  *",{{ g }},"*) exec "$user_shell" ;;
{% endfor %}esac
{% endif %}
case "$SSH_ORIGINAL_COMMAND" in
  # Binary file-transfer protocols: tlog cannot record them and its pty layer corrupts framing.
  # Pass through to the user's real shell unrecorded (covered by auditd path-watch rules).
  "scp -"*|"rsync --server"*|"/usr/lib/openssh/sftp-server"*|"internal-sftp"*)
    exec "$user_shell" -c "$SSH_ORIGINAL_COMMAND"
    ;;
  "")
    # Interactive login: record an interactive shell.
    exec /usr/bin/tlog-rec-session
    ;;
  *)
    # Remote command (ssh host "cmd"): allocate pty and record.
    exec /usr/bin/tlog-rec-session -c "$SSH_ORIGINAL_COMMAND"
    ;;
esac
